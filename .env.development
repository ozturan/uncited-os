# uncited-os local development config (loaded automatically by `next dev`)
#
# These point at the local Supabase stack that `./up.sh` (supabase start) runs
# on your machine. The two keys below are Supabase's well-known LOCAL demo keys,
# signed with the default local JWT secret. They are NOT secrets: they only work
# against a Supabase instance running on localhost. Never reuse them for a hosted
# deployment.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# Single-user local mode: open straight to the dashboard, no login.
NEXT_PUBLIC_SINGLE_USER_MODE=true

# Let the RSS fetch pipeline (npm run populate) write papers/sightings.
DUAL_WRITE_CANONICAL=true

# --- Optional: semantic recommendations (Level 2) ---
# Add your own OpenAI key to embed papers at ingest time and unlock the
# embedding-based "For You" / Discover ranking. This costs money per ingest.
# Without it, uncited-os is a full RSS reader (browse, follow, search, star,
# read-tracking) with no embedding-based recommendations.
# OPENAI_API_KEY=sk-...
# ENABLE_EMBEDDINGS=true
